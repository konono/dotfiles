### Alias
alias ll="gls -alh --color=auto"
alias less='less -r -SX' # lessで見た時にエスケープシーケンスなどを綺麗に取る
alias gip="egrep -o '([1-2]?[0-9]{0,2}\.){3,3}[1-2]?[0-9]{0,2}'" # grep ip address 
alias dyy="date '+%Y%m%d%H%M%S'"
alias vi='nvim'
alias vim='nvim'
alias nvf='nvim -d'
alias sudo='sudo ' # magic
alias tk='texit'
alias sed='gsed'
alias grep='ggrep'
alias history='history 0'
alias gpip='`which python3` -m pip'
alias certbot='certbot --config-dir ./config --work-dir ./work --logs-dir ./logs'
